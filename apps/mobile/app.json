{
  "expo": {
    "name": "Patrol System",
    "slug": "patrol-system",
    "scheme": "patrolsystem",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.patrolsystem.mobile"
    },
    "android": {
      "package": "com.patrolsystem.mobile",
      "permissions": ["NFC", "ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Приложение использует NFC для считывания меток контрольных точек."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Геолокация прикрепляется к событиям обхода для контроля маршрута."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:3000/api/v1"
    }
  }
}
