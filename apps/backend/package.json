{
  "name": "@patrol/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "prestart:dev": "npm run build -w @patrol/shared",
    "seed:manual": "ts-node -r tsconfig-paths/register src/database/seeds/manual-check.seed.ts",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "@patrol/shared": "0.1.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "latest",
    "pg": "^8.12.0",
    "reflect-metadata": "latest",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@types/bcrypt": "latest",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "latest",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.5.4"
  }
}
